FROM python:3.9-slim

WORKDIR /app

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install development dependencies (if you need them)
COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

# Optionally, also install minimal requirements as needed:
# COPY requirements-minimal.txt .
# RUN pip install --no-cache-dir -r requirements-minimal.txt

# Copy the application code
COPY . .

# Set environment variables for backend services if needed
ENV VALIDATOR_PATH=/app/validator/OpenSCENARIOValidator
ENV LD_LIBRARY_PATH=/app/validator
ENV PORT=8080
ENV LOG_LEVEL=DEBUG

# Expose the port the app runs on
EXPOSE 8080

# Command to run the application with auto-reload
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]

